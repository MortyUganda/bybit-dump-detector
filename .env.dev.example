# ============================================================
# DEV ENVIRONMENT — тестовый экземпляр бота
# ============================================================
# Этот файл используется docker-compose.dev.yml
# Скопируйте: cp .env.dev.example .env.dev
# Заполните TELEGRAM_BOT_TOKEN вторым (тестовым) токеном бота

# ============================================================
# TELEGRAM (ОБЯЗАТЕЛЬНО: нужен ОТДЕЛЬНЫЙ бот для dev!)
# ============================================================
# Создайте второго бота через @BotFather (например, MyBot_Dev)
TELEGRAM_BOT_TOKEN=your_dev_bot_token_here
# Comma-separated Telegram user IDs
TELEGRAM_ALLOWED_USERS=

# ============================================================
# BYBIT API (можно использовать те же ключи что и в prod)
# ============================================================
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_NETWORK=mainnet

# ============================================================
# POSTGRESQL (хост и порт внутри Docker-сети, не менять)
# ============================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dumpdetector
POSTGRES_USER=dumpuser
POSTGRES_PASSWORD=strongpassword123

# ============================================================
# REDIS (хост и порт внутри Docker-сети, не менять)
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================
# UNIVERSE FILTER DEFAULTS
# ============================================================
UNIVERSE_MIN_24H_VOLUME_USDT=500000
UNIVERSE_MIN_TRADES_PER_HOUR=50
UNIVERSE_MIN_LISTING_AGE_DAYS=14
UNIVERSE_EXCLUDE_SYMBOLS=BTC,ETH,BNB,SOL,XRP,ADA,DOGE,AVAX,DOT,MATIC,LTC,LINK,UNI,ATOM,TRX

# ============================================================
# SCORING THRESHOLDS
# ============================================================
SCORE_ALERT_THRESHOLD=50
SCORE_CRITICAL_THRESHOLD=75

# ============================================================
# ALERT COOLDOWN
# ============================================================
ALERT_COOLDOWN_MINUTES=60

# ============================================================
# FEATURE WINDOWS (minutes)
# ============================================================
FEATURE_WINDOW_SHORT=5
FEATURE_WINDOW_MEDIUM=15
FEATURE_WINDOW_LONG=60

# ============================================================
# APP
# ============================================================
LOG_LEVEL=DEBUG
ENV=development
OVERVALUED_TOP_N=20
UNIVERSE_REFRESH_INTERVAL=300
