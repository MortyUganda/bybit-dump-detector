# ============================================================
# TELEGRAM
# ============================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs allowed to use the bot
# Leave empty for public access (not recommended for production)
TELEGRAM_ALLOWED_USERS=

# ============================================================
# BYBIT API (read-only keys sufficient for market data)
# ============================================================
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
# testnet or mainnet
BYBIT_NETWORK=mainnet

# ============================================================
# POSTGRESQL
# ============================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dumpdetector
POSTGRES_USER=dumpuser
POSTGRES_PASSWORD=strongpassword123
# Built automatically from above — override if needed
# DATABASE_URL=postgresql+asyncpg://dumpuser:strongpassword123@postgres:5432/dumpdetector

# ============================================================
# REDIS
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================
# UNIVERSE FILTER DEFAULTS
# (all thresholds are calibration targets — adjust after 1 week live)
# ============================================================
# Minimum 24h USDT volume to include a coin
UNIVERSE_MIN_24H_VOLUME_USDT=500000
# Minimum number of trades per hour to consider "liquid enough"
UNIVERSE_MIN_TRADES_PER_HOUR=50
# Maximum age of listing (days) — skip brand-new listings
UNIVERSE_MIN_LISTING_AGE_DAYS=14
# Coins to always exclude (comma-separated base assets)
UNIVERSE_EXCLUDE_SYMBOLS=BTC,ETH,BNB,SOL,XRP,ADA,DOGE,AVAX,DOT,MATIC,LTC,LINK,UNI,ATOM,TRX

# ============================================================
# SCORING THRESHOLDS
# ============================================================
# Risk levels: 0-24 low | 25-49 moderate | 50-74 high | 75-100 critical
SCORE_ALERT_THRESHOLD=50
SCORE_CRITICAL_THRESHOLD=75

# ============================================================
# ALERT COOLDOWN
# ============================================================
# Minimum minutes between two alerts for the same coin (per signal type)
ALERT_COOLDOWN_MINUTES=60

# ============================================================
# FEATURE WINDOWS (minutes)
# ============================================================
FEATURE_WINDOW_SHORT=5
FEATURE_WINDOW_MEDIUM=15
FEATURE_WINDOW_LONG=60

# ============================================================
# APP
# ============================================================
LOG_LEVEL=INFO
ENV=development
# How many coins to show in /overvalued list
OVERVALUED_TOP_N=20
# Refresh interval for universe scan (seconds)
UNIVERSE_REFRESH_INTERVAL=300
