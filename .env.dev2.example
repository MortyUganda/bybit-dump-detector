# ============================================================
# DEV2 ENVIRONMENT — второй тестовый экземпляр
# ============================================================
# Скопируйте: cp .env.dev2.example .env.dev2
# Нужен ТРЕТИЙ бот через @BotFather

TELEGRAM_BOT_TOKEN=your_dev2_bot_token_here
TELEGRAM_ALLOWED_USERS=

BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_NETWORK=mainnet

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dumpdetector
POSTGRES_USER=dumpuser
POSTGRES_PASSWORD=strongpassword123

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

UNIVERSE_MIN_24H_VOLUME_USDT=500000
UNIVERSE_MIN_TRADES_PER_HOUR=50
UNIVERSE_MIN_LISTING_AGE_DAYS=14
UNIVERSE_EXCLUDE_SYMBOLS=BTC,ETH,BNB,SOL,XRP,ADA,DOGE,AVAX,DOT,MATIC,LTC,LINK,UNI,ATOM,TRX

SCORE_ALERT_THRESHOLD=50
SCORE_CRITICAL_THRESHOLD=75

ALERT_COOLDOWN_MINUTES=60

FEATURE_WINDOW_SHORT=5
FEATURE_WINDOW_MEDIUM=15
FEATURE_WINDOW_LONG=60

LOG_LEVEL=DEBUG
ENV=development
OVERVALUED_TOP_N=20
UNIVERSE_REFRESH_INTERVAL=300
